{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/snapshot.sh",
            "timeout": 10,
            "description": "Snapshot high-signal files (IDEA, BLUEPRINT, README, SECURITY, CHANGELOG) to STATE/.snapshots/"
          }
        ]
      }
    ]
  }
}
