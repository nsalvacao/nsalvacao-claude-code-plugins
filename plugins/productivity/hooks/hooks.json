{
  "Stop": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-close.sh",
          "timeout": 5,
          "description": "Remind to update tasks at session end if TASKS.md has active items"
        }
      ]
    }
  ]
}
