{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "idea-auditor/blueprint",
  "title": "Blueprint",
  "description": "Optional deeper spec — architecture, UX, channels, pricing, risks.",
  "type": "object",
  "properties": {
    "architecture_summary": { "type": "string" },
    "ux_flow": { "type": "string" },
    "distribution_channels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pricing_model": { "type": "string" },
    "technical_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "migration_notes": {
      "type": "string",
      "description": "Relevant for Infra_Fork_Standard mode — switching costs, rollback feasibility."
    }
  }
}
