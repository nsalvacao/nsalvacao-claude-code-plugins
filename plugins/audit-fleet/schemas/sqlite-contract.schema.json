{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "audit-fleet/sqlite-contract",
  "title": "Audit Fleet SQLite Contract",
  "description": "Export contract for audit-fleet lifecycle state stored in SQLite.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "database",
    "generated_at",
    "lifecycle",
    "todos",
    "todo_deps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "database": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statuses", "transitions"],
      "properties": {
        "statuses": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "blocked"]
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string",
                "enum": ["pending", "in_progress", "done", "blocked"]
              },
              "to": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "enum": ["pending", "in_progress", "done", "blocked"]
                }
              }
            }
          }
        }
      }
    },
    "todos": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "description", "status", "created_at", "updated_at"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "blocked"]
          },
          "created_at": {"type": "string", "format": "date-time"},
          "updated_at": {"type": "string", "format": "date-time"}
        }
      }
    },
    "todo_deps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["todo_id", "depends_on", "created_at"],
        "properties": {
          "todo_id": {"type": "string", "minLength": 1},
          "depends_on": {"type": "string", "minLength": 1},
          "created_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  }
}
