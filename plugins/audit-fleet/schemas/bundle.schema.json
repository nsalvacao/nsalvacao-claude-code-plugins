{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "audit-fleet/bundle",
  "title": "Audit Fleet Bundle",
  "description": "Deterministic aggregate bundle for all fixed audit-fleet reports.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "mode",
    "generated_at",
    "required_reports",
    "report_count",
    "reports",
    "totals"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "mode": {
      "type": "string",
      "enum": ["strict", "balanced"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "required_reports": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[0-9]{2}-[a-z0-9][a-z0-9-]*\\.md$"
      }
    },
    "report_count": {
      "type": "integer",
      "minimum": 0
    },
    "reports": {
      "type": "array",
      "items": {
        "$ref": "report.schema.json"
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["findings_total", "by_severity"],
      "properties": {
        "findings_total": {
          "type": "integer",
          "minimum": 0
        },
        "by_severity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["critical", "warning", "info"],
          "properties": {
            "critical": {"type": "integer", "minimum": 0},
            "warning": {"type": "integer", "minimum": 0},
            "info": {"type": "integer", "minimum": 0}
          }
        }
      }
    }
  }
}
